<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- The INTERNET permission is required for development. Specifically,
         the Flutter tool needs it to communicate with the running application
         to allow setting breakpoints, to provide hot reload, etc.
    -->
    <uses-permission android:name="android.permission.INTERNET"/>

    <application>
        <!--
          Force the Skia/OpenGLES renderer for debug builds.

          Flutter defaults to the Impeller/Vulkan renderer, which we keep in
          release for premium visual quality. However, the Android emulator's
          software Vulkan (SwiftShader) is unstable under Impeller and crashes the
          emulator's GPU process, which makes headless integration tests
          impossible. Debug builds — including `flutter test integration_test/…`
          on the emulator — therefore fall back to Skia, which is stable on
          SwiftShader. Release builds are unaffected and keep Impeller.
        -->
        <meta-data
            android:name="io.flutter.embedding.android.EnableImpeller"
            android:value="false" />
    </application>
</manifest>
